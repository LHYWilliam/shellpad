          "group_id": "22222222-2222-2222-2222-222222222222",
          "shell": "bash",
          "exec_mode": "stop_on_error",
          "variables": [
            { "name": "host", "default_value": "user@prod.example.com" },
            { "name": "tag", "default_value": "latest" }
          ],
          "commands": [
            { "position": 0, "command": "docker build -t myapp:{{tag}} ." },
            { "position": 1, "command": "docker push myapp:{{tag}}" },
            { "position": 2, "command": "ssh {{host}} 'docker pull myapp:{{tag}} && docker compose up -d'" }
          ],
          "working_dir": "/home/user/project",
