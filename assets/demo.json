          "shell": "bash",
          "exec_mode": "stop_on_error",
          "variables": [
            { "name": "host", "default_value": "user@staging.example.com" },
            { "name": "path", "default_value": "/var/www/app" }
          ],
          "commands": [
            { "position": 0, "command": "cargo build --release" },
            { "position": 1, "command": "rsync -avz target/release/ {{host}}:{{path}}/" },
            { "position": 2, "command": "ssh {{host}} 'systemctl restart myapp'" }
          ],
          "working_dir": "/home/user/project",
          "created_at": "2026-06-17T10:00:00Z",
          "updated_at": "2026-06-17T10:00:00Z"
